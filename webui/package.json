    "@types/react-syntax-highlighter": "^15.5.11",
    "@vitejs/plugin-react": "^5.0.1",
    "eslint": "^9.39.4",
    "sass": "^1.98.0",
    "typescript": "^5.3.3",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
