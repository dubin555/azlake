    "remark-html": "^15.0.2",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.0",
    "unified": "^11.0.4",
    "unist-util-visit": "^4.1.2",
    "validator": "^13.11.0",
    "vite-plugin-eslint2": "^5.1.0"
  },
  "devDependencies": {
    "@rollup/plugin-replace": "^5.0.5",
    "@types/lodash": "^4.14.202",
    "@types/node": "^20.10.4",
