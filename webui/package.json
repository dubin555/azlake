{
  "name": "azlake-ui",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">= 18"
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react",
    "prismjs": "$prismjs"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "postbuild": "touch dist/.gitkeep",
    "serve": "vite preview",
    "test": "vitest run",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,scss,md}\""
  },
  "dependencies": {
    "@duckdb/duckdb-wasm": "1.28.0",
